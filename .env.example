# Copy this file to .env and fill in the values before running:
#   cp .env.example .env

# ── Required ───────────────────────────────────────────────────────────────────

# Full URL of the GitHub repository this runner will serve.
GITHUB_URL=https://github.com/your-org/your-repo

# A GitHub Personal Access Token (classic) with the "repo" scope.
# Used to automatically obtain a runner registration token on first startup.
# Prefer RUNNER_TOKEN (below) — it is the standard GitHub-issued runner token
# with exactly the permissions GitHub grants a runner, requiring no extra PAT.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Optional ───────────────────────────────────────────────────────────────────

# Display name of this runner in the GitHub Actions UI (default: minmax-runner).
# RUNNER_NAME=minmax-runner

# Comma-separated runner labels (default: self-hosted-minmax,minmax).
# The workflow uses `runs-on: self-hosted-minmax`, so keep "self-hosted" in the list.
# RUNNER_LABELS=self-hosted-minmax,minmax

# One-time registration token shown in the "Configure" step at:
#   Settings → Actions → Runners → New self-hosted-minmax runner (bottom of the page,
#   inside the ./config.sh --token <VALUE> command).
# Only needed on first startup. Expires 1 hour after generation.
RUNNER_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
